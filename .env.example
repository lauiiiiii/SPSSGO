# Runtime
APP_ENV=production
ALLOW_INSECURE_DEV_DEFAULTS=0
JOB_BACKEND=celery
DB_AUTO_CREATE=0
APP_IMAGE=spssgo-app:local
WORKER_SANDBOX_IMAGE=spssgo-worker-sandbox:local
LOG_LEVEL=INFO
LOG_JSON=1
METRICS_ENABLED=1
CORS_ALLOW_ORIGINS=http://localhost:5577,http://127.0.0.1:5577,http://localhost:5578,http://127.0.0.1:5578
PROMETHEUS_RETENTION=15d
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now
ADMIN_SECRET_KEY=replace-with-a-long-random-secret
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# References
# 用于报告参考文献前两条平台引用；平台日期填上线/更新日期，论文日期填用户论文撰写日期。
SPSSGO_REFERENCE_VERSION=1.0.0
SPSSGO_PLATFORM_REFERENCE_DATE=202X-XX-XX
SPSSGO_PAPER_REFERENCE_DATE=202X-XX-XX

# AI
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0

# MySQL
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_HOST_PORT=3307
MYSQL_USER=spssgo
MYSQL_PASSWORD=change-me-now
MYSQL_ROOT_PASSWORD=change-root-password
MYSQL_DATABASE=data_analysis
MYSQL_MAX_CONNECTIONS=200
MYSQL_POOL_MINSIZE=1
MYSQL_POOL_MAXSIZE=4
ANALYSIS_WORKER_CONCURRENCY=4
REPORT_WORKER_CONCURRENCY=2
AI_WORKER_CONCURRENCY=2

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Optional failure-drill helpers
FAULT_INJECTION_JOB_DELAY_SECONDS=0
FAULT_INJECTION_JOB_DELAY_TYPES=execute_method

# Sandbox
SANDBOX_DOCKER_ENABLED=1
SANDBOX_DOCKER_BIN=docker
SANDBOX_DOCKER_IMAGE=spssgo-app:local
SANDBOX_DOCKER_MEMORY_LIMIT=768m
SANDBOX_DOCKER_CPUS=1.0
SANDBOX_DOCKER_PIDS_LIMIT=128
SANDBOX_WORKER_CONCURRENCY=2
SANDBOX_CONTAINER_USER=65534:65534
SANDBOX_WORKSPACE_SIZE=256m
SANDBOX_TMP_SIZE=128m
SANDBOX_SHARED_STORAGE_VOLUME=spssgo-storage-data
SANDBOX_SHARED_STORAGE_TARGET=/var/lib/spssgo/storage

# R runtime
R_ENABLED=1
RSCRIPT_BIN=C:\Program Files\R\R-4.5.3\bin\Rscript.exe
R_EXECUTION_TIMEOUT_SECONDS=120
R_LIBS_USER=C:\Users\YOUR_USER\AppData\Roaming\R\win-library\4.5
R_TEMP_DIR=./.tmp/rtemp

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=/var/lib/spssgo/storage
S3_ENDPOINT_URL=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_KEY_PREFIX=
